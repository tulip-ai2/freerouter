# FreeRouter environment contract
# Railway auto-injects: PORT, RAILWAY_PUBLIC_DOMAIN, RAILWAY_PRIVATE_DOMAIN

# Required
JWT_SECRET=CHANGE_ME_GENERATE_STRONG_PASSWORD
INITIAL_PASSWORD=changeme123
DATA_DIR=/var/lib/freerouter

# Recommended runtime variables
PORT=20128
NODE_ENV=production

# Recommended security and ops variables
API_KEY_SECRET=endpoint-proxy-secret-key
MACHINE_ID_SALT=freerouter-proxy-salt
ENABLE_REQUEST_LOGS=false
OBSERVABILITY_ENABLED=true
AUTH_COOKIE_SECURE=true
REQUIRE_API_KEY=false

# Cloud sync variables
# Railway: auto-detected from RAILWAY_PUBLIC_DOMAIN, fallback to localhost
BASE_URL=http://localhost:20128
CLOUD_URL=https://freerouter.app
NEXT_PUBLIC_BASE_URL=http://localhost:20128
NEXT_PUBLIC_CLOUD_URL=https://freerouter.app

# Optional outbound proxy variables for upstream provider calls
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# ALL_PROXY=socks5://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1

# === AI Provider API Keys ===
# Add your keys below (or set via Railway dashboard)

# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...
# GROQ_API_KEY=...
# OPENROUTER_API_KEY=...
