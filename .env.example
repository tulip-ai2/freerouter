# FreeRouter environment contract
# Railway auto-injects: PORT, RAILWAY_PUBLIC_DOMAIN, RAILWAY_PRIVATE_DOMAIN

# ============================================
# REQUIRED - MUST SET BEFORE DEPLOYMENT
# ============================================

# Generate a strong random string (min 32 chars)
# Example: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_GENERATE_STRONG_PASSWORD

# Initial admin password for first login
INITIAL_PASSWORD=changeme123

# ============================================
# DATA STORAGE
# ============================================

DATA_DIR=/var/lib/freerouter

# ============================================
# RECOMMENDED RUNTIME
# ============================================

NODE_ENV=production
PORT=20128

# ============================================
# SECURITY & OPS
# ============================================

API_KEY_SECRET=endpoint-proxy-secret-key
MACHINE_ID_SALT=freerouter-proxy-salt
ENABLE_REQUEST_LOGS=false
OBSERVABILITY_ENABLED=true
AUTH_COOKIE_SECURE=true
REQUIRE_API_KEY=false

# ============================================
# 🚂 RAILWAY DEPLOYMENT - CRITICAL!
# ============================================
# Railway auto-provides: RAILWAY_PUBLIC_DOMAIN
# You MUST set these manually in Railway Dashboard > Variables:

# NEXT_PUBLIC_BASE_URL=https://your-app.railway.app
# (Replace "your-app" with your actual Railway deployment URL)
# This tells the frontend what public URL to use for API calls

# BASE_URL=https://your-app.railway.app
# (Same as NEXT_PUBLIC_BASE_URL but for server-side internal calls)

# ============================================
# CLOUD SYNC (Optional - disable if not needed)
# ============================================

CLOUD_URL=https://freerouter.app
NEXT_PUBLIC_CLOUD_URL=https://freerouter.app

# ============================================
# PROXY SETTINGS (Optional)
# ============================================

# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# ALL_PROXY=socks5://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1

# ============================================
# AI PROVIDER API KEYS (add as needed)
# ============================================

# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...
# GROQ_API_KEY=...
# OPENROUTER_API_KEY=...
